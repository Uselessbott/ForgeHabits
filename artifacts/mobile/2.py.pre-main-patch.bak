#!/usr/bin/env python3
"""
ForgeHabits Appearance System Upgrade – Single Incremental Patcher

Applies all 13 patches in sequence. Each patch modifies exactly one file,
preserving everything else. Stops immediately if a required pattern is missing.

Backups: <filename>.pre-appearance.bak
"""

import shutil
import sys
from pathlib import Path

ROOT = Path.home() / "ForgeHabits" / "artifacts" / "mobile"

def fail(file, msg):
    print(f"❌ [{file}] {msg}")
    sys.exit(1)

def backup(path):
    dest = path.with_suffix(path.suffix + ".pre-appearance.bak")
    shutil.copy2(path, dest)
    print(f"📦 Backed up: {path} → {dest}")

# ---------------------------------------------------------------------------
# Patch 1: context/types.ts
# ---------------------------------------------------------------------------
def patch_types():
    file = ROOT / "context/types.ts"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    content = file.read_text(encoding="utf-8")

    old_theme = "  theme: 'dark' | 'light';"
    new_theme = "  theme: 'super_amoled' | 'light';"
    if old_theme not in content:
        fail(file, f"Expected theme field not found")
    content = content.replace(old_theme, new_theme, 1)

    accent_line = "  accentColor: 'orange' | 'red' | 'maroon' | 'blue' | 'green' | 'purple' | 'pink' | 'cyan' | 'yellow';"
    if new_theme not in content:
        fail(file, "Theme field insertion point missing after replacement")
    content = content.replace(new_theme + "\n", new_theme + "\n" + accent_line + "\n", 1)

    file.write_text(content, encoding="utf-8")
    print(f"✅ {file.name}: Updated theme type, added accentColor")

# ---------------------------------------------------------------------------
# Patch 2: constants/colors.ts
# ---------------------------------------------------------------------------
def patch_colors():
    file = ROOT / "constants/colors.ts"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    marker = "const colors = {"
    if marker not in orig:
        fail(file, "Marker 'const colors = {' not found")

    prepend = """\
export type ThemeKey = 'super_amoled' | 'light';
export type AccentKey =
  | 'orange'
  | 'red'
  | 'maroon'
  | 'blue'
  | 'green'
  | 'purple'
  | 'pink'
  | 'cyan'
  | 'yellow';

export const ACCENT_KEYS: AccentKey[] = [
  'orange',
  'red',
  'maroon',
  'blue',
  'green',
  'purple',
  'pink',
  'cyan',
  'yellow',
];

export const ACCENT_MAP: Record<AccentKey, string> = {
  orange: '#E05A1A',
  red: '#EF4444',
  maroon: '#800000',
  blue: '#3B82F6',
  green: '#22C55E',
  purple: '#8B5CF6',
  pink: '#EC4899',
  cyan: '#06B6D4',
  yellow: '#F59E0B',
};

export interface ColorPalette {
  text: string;
  tint: string;
  background: string;
  foreground: string;
  card: string;
  cardForeground: string;
  primary: string;
  primaryForeground: string;
  secondary: string;
  secondaryForeground: string;
  muted: string;
  mutedForeground: string;
  accent: string;
  accentForeground: string;
  destructive: string;
  destructiveForeground: string;
  border: string;
  input: string;
  success: string;
  warning: string;
  surface: string;
}

export function generateColors(theme: ThemeKey, accentKey: AccentKey): ColorPalette {
  const accentHex = ACCENT_MAP[accentKey];

  if (theme === 'super_amoled') {
    return {
      text: '#F2F2F2',
      tint: accentHex,
      background: '#000000',
      foreground: '#F2F2F2',
      card: '#0A0A0A',
      cardForeground: '#F2F2F2',
      primary: accentHex,
      primaryForeground: '#FFFFFF',
      secondary: '#1A1A1A',
      secondaryForeground: '#F2F2F2',
      muted: '#1A1A1A',
      mutedForeground: '#555555',
      accent: accentHex,
      accentForeground: '#FFFFFF',
      destructive: '#EF4444',
      destructiveForeground: '#FFFFFF',
      border: '#1E1E1E',
      input: '#181818',
      success: '#22C55E',
      warning: '#F59E0B',
      surface: '#0A0A0A',
    };
  }

  // light
  return {
    text: '#0a0a0a',
    tint: accentHex,
    background: '#FFFFFF',
    foreground: '#0a0a0a',
    card: '#F4F4F4',
    cardForeground: '#0a0a0a',
    primary: accentHex,
    primaryForeground: '#ffffff',
    secondary: '#f0f0f0',
    secondaryForeground: '#1a1a1a',
    muted: '#f0f0f0',
    mutedForeground: '#737373',
    accent: accentHex,
    accentForeground: '#ffffff',
    destructive: '#ef4444',
    destructiveForeground: '#ffffff',
    border: '#e5e5e5',
    input: '#ebebeb',
    success: '#22C55E',
    warning: '#F59E0B',
    surface: '#F8F8F8',
  };
}

"""
    orig = orig.replace(marker, prepend + marker, 1)
    print(f"  ✅ Prepended types, accent map, and generateColors()")

    # Replace light palette
    old_light = (
        "  light: {\n"
        "    text: '#0a0a0a',\n"
        "    tint: '#E05A1A',\n"
        "    background: '#F8F8F8',\n"
        "    foreground: '#0a0a0a',\n"
        "    card: '#ffffff',\n"
        "    cardForeground: '#0a0a0a',\n"
        "    primary: '#E05A1A',\n"
        "    primaryForeground: '#ffffff',\n"
        "    secondary: '#f0f0f0',\n"
        "    secondaryForeground: '#1a1a1a',\n"
        "    muted: '#f0f0f0',\n"
        "    mutedForeground: '#737373',\n"
        "    accent: '#E05A1A',\n"
        "    accentForeground: '#ffffff',\n"
        "    destructive: '#ef4444',\n"
        "    destructiveForeground: '#ffffff',\n"
        "    border: '#e5e5e5',\n"
        "    input: '#ebebeb',\n"
        "    success: '#22C55E',\n"
        "    warning: '#F59E0B',\n"
        "    surface: '#f4f4f4',\n"
        "  },"
    )
    new_light = "  light: generateColors('light', 'orange'),"
    if old_light not in orig:
        fail(file, "Light palette object not found")
    orig = orig.replace(old_light, new_light, 1)
    print("  ✅ Replaced light palette with generateColors call")

    # Replace dark palette
    old_dark = (
        "  dark: {\n"
        "    text: '#F2F2F2',\n"
        "    tint: '#E05A1A',\n"
        "    background: '#080808',\n"
        "    foreground: '#F2F2F2',\n"
        "    card: '#111111',\n"
        "    cardForeground: '#F2F2F2',\n"
        "    primary: '#E05A1A',\n"
        "    primaryForeground: '#FFFFFF',\n"
        "    secondary: '#1A1A1A',\n"
        "    secondaryForeground: '#F2F2F2',\n"
        "    muted: '#1A1A1A',\n"
        "    mutedForeground: '#555555',\n"
        "    accent: '#E05A1A',\n"
        "    accentForeground: '#FFFFFF',\n"
        "    destructive: '#EF4444',\n"
        "    destructiveForeground: '#FFFFFF',\n"
        "    border: '#1E1E1E',\n"
        "    input: '#181818',\n"
        "    success: '#22C55E',\n"
        "    warning: '#F59E0B',\n"
        "    surface: '#131313',\n"
        "  },"
    )
    new_dark = "  dark: generateColors('super_amoled', 'orange'),"
    if old_dark not in orig:
        fail(file, "Dark palette object not found")
    orig = orig.replace(old_dark, new_dark, 1)
    print("  ✅ Replaced dark palette with generateColors call")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Centralized theme generator added")

# ---------------------------------------------------------------------------
# Patch 3: hooks/useColors.ts
# ---------------------------------------------------------------------------
def patch_useColors():
    file = ROOT / "hooks/useColors.ts"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    # Remove useColorScheme import
    for imp in [
        'import { useColorScheme } from "react-native";',
        "import { useColorScheme } from 'react-native';",
    ]:
        if imp in orig:
            orig = orig.replace(imp, "", 1)
            break
    else:
        fail(file, "useColorScheme import not found")
    print("  ✅ Removed useColorScheme import")

    # Add new imports after the colors import
    import_colors = 'import colors from "@/constants/colors";'
    if import_colors not in orig:
        import_colors = "import colors from '@/constants/colors';"
    if import_colors not in orig:
        fail(file, "colors import not found")
    new_imports = (
        import_colors + "\n"
        "import { useHabits } from '@/context/HabitsContext';\n"
        "import { generateColors, type ThemeKey, type AccentKey } from '@/constants/colors';\n"
    )
    orig = orig.replace(import_colors, new_imports, 1)
    print("  ✅ Added useHabits and type imports")

    # Replace function body
    old_body = (
        "export function useColors() {\n"
        "  const scheme = useColorScheme();\n"
        "  const palette =\n"
        '    scheme === "dark" && "dark" in colors\n'
        "      ? (colors as unknown as Record<string, typeof colors.light>).dark\n"
        "      : colors.light;\n"
        "  return { ...palette, radius: colors.radius };\n"
        "}"
    )
    if old_body not in orig:
        fail(file, "useColors function body not found")
    new_body = (
        "export function useColors() {\n"
        "  const { settings } = useHabits();\n"
        "\n"
        "  const theme: ThemeKey =\n"
        "    settings.theme === 'light' ? 'light' : 'super_amoled';\n"
        "\n"
        "  const accent: AccentKey =\n"
        "    (settings as any).accentColor in colors\n"
        "      ? (settings as any).accentColor\n"
        "      : 'orange';\n"
        "\n"
        "  const palette = generateColors(theme, accent);\n"
        "  return { ...palette, radius: colors.radius };\n"
        "}"
    )
    orig = orig.replace(old_body, new_body, 1)
    print("  ✅ Replaced useColors logic with settings-based theme")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Theme-aware hook")

# ---------------------------------------------------------------------------
# Patch 4: app/_layout.tsx
# ---------------------------------------------------------------------------
def patch_root_layout():
    file = ROOT / "app/_layout.tsx"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    err_import = "import { ErrorBoundary } from '@/components/ErrorBoundary';"
    if err_import not in orig:
        fail(file, "ErrorBoundary import not found")
    orig = orig.replace(err_import, err_import + "\nimport { useColors } from '@/hooks/useColors';", 1)
    print("  ✅ Added useColors import")

    hook_line = "  const { updateSettings } = useHabits();"
    if hook_line not in orig:
        fail(file, "updateSettings line not found")
    orig = orig.replace(hook_line, "  const colors = useColors();\n  const { updateSettings } = useHabits();", 1)
    print("  ✅ Added colors variable")

    old_bg = "        contentStyle: { backgroundColor: '#080808' },"
    if old_bg not in orig:
        fail(file, "Hardcoded background not found")
    orig = orig.replace(old_bg, "        contentStyle: { backgroundColor: colors.background },", 1)
    print("  ✅ Replaced background with dynamic color")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Dynamic background")

# ---------------------------------------------------------------------------
# Patch 5: app/(tabs)/_layout.tsx
# ---------------------------------------------------------------------------
def patch_tab_layout():
    file = ROOT / "app/(tabs)/_layout.tsx"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    old_rn = "import { Platform, StyleSheet, useColorScheme, View } from 'react-native';"
    new_rn = "import { Platform, StyleSheet, View } from 'react-native';"
    if old_rn not in orig:
        fail(file, "react-native import with useColorScheme not found")
    orig = orig.replace(old_rn, new_rn, 1)
    print("  ✅ Removed useColorScheme import")

    colors_import = "import { useColors } from '@/hooks/useColors';"
    if colors_import not in orig:
        fail(file, "useColors import not found")
    orig = orig.replace(colors_import, colors_import + "\nimport { useHabits } from '@/context/HabitsContext';", 1)
    print("  ✅ Added useHabits import")

    old_dark = "  const isDark = useColorScheme() === 'dark';"
    if old_dark not in orig:
        fail(file, "isDark line not found")
    orig = orig.replace(old_dark, "  const { settings } = useHabits();\n  const isDark = settings.theme !== 'light';", 1)
    print("  ✅ Replaced isDark with theme check")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Tab bar respects theme")

# ---------------------------------------------------------------------------
# Patch 6: context/HabitsContext.tsx
# ---------------------------------------------------------------------------
def patch_habits_context():
    file = ROOT / "context/HabitsContext.tsx"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    # 1) DEFAULT_SETTINGS
    old_theme = "  theme: 'dark',"
    if old_theme not in orig:
        fail(file, "DEFAULT_SETTINGS theme field not found")
    new_default = "  theme: 'super_amoled',\n  accentColor: 'orange',"
    orig = orig.replace(old_theme, new_default, 1)
    print("  ✅ Updated DEFAULT_SETTINGS with new theme and accentColor")

    # 2) Migration after loading settings
    load_line = "        const loadedSettings: AppSettings = s ? { ...DEFAULT_SETTINGS, ...JSON.parse(s) } : DEFAULT_SETTINGS;"
    if load_line not in orig:
        fail(file, "Loaded settings line not found")
    migration = """        // Migrate legacy 'dark' theme to 'super_amoled'
        if (loadedSettings.theme === 'dark' as any) {
          loadedSettings.theme = 'super_amoled' as any;
        }
        if (!(loadedSettings as any).accentColor) {
          (loadedSettings as any).accentColor = 'orange';
        }"""
    orig = orig.replace(load_line, load_line + "\n" + migration, 1)
    print("  ✅ Added legacy theme migration")

    # 3) Extend snapshot
    old_snapshot = "      const snapshot = {\n        version: 1,"
    if old_snapshot not in orig:
        fail(file, "Snapshot object header not found")
    new_snapshot = "      const snapshot = {\n        version: 1,\n        theme: settings.theme,\n        accentColor: (settings as any).accentColor ?? 'orange',"
    orig = orig.replace(old_snapshot, new_snapshot, 1)
    print("  ✅ Added theme & accentColor to widget snapshot")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Settings migration, snapshot extended")

# ---------------------------------------------------------------------------
# Patch 7: app/(tabs)/settings.tsx
# ---------------------------------------------------------------------------
def patch_settings_screen():
    file = ROOT / "app/(tabs)/settings.tsx"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    import_colors = "import { useColors } from '@/hooks/useColors';"
    if import_colors not in orig:
        fail(file, "useColors import not found")
    orig = orig.replace(import_colors, import_colors + "\nimport { ACCENT_KEYS, ACCENT_MAP, type AccentKey } from '@/constants/colors';", 1)
    print("  ✅ Added ACCENT_KEYS, ACCENT_MAP imports")

    settings_comment = "        {/* Settings */}"
    if settings_comment not in orig:
        fail(file, "Settings section comment not found")

    appearance_block = """        {/* Appearance */}
        <Text style={[styles.sectionTitle, { color: colors.mutedForeground }]}>APPEARANCE</Text>
        <View style={[styles.card, { backgroundColor: colors.card, borderColor: colors.border, padding: 16 }]}>
          <Text style={[styles.settingLabel, { color: colors.foreground, marginBottom: 12 }]}>Theme</Text>
          {(['super_amoled', 'light'] as const).map((t) => (
            <TouchableOpacity
              key={t}
              onPress={() => updateSettings({ theme: t })}
              style={{ flexDirection: 'row', alignItems: 'center', marginBottom: 8 }}
              activeOpacity={0.7}
            >
              <View style={{
                width: 20,
                height: 20,
                borderRadius: 10,
                borderWidth: 2,
                borderColor: settings.theme === t ? colors.primary : colors.border,
                justifyContent: 'center',
                alignItems: 'center',
                marginRight: 10,
              }}>
                {settings.theme === t && (
                  <View style={{
                    width: 10,
                    height: 10,
                    borderRadius: 5,
                    backgroundColor: colors.primary,
                  }} />
                )}
              </View>
              <Text style={{ color: colors.foreground, fontSize: 14, fontFamily: 'Inter_500Medium' }}>
                {t === 'super_amoled' ? 'Super AMOLED' : 'Light'}
              </Text>
            </TouchableOpacity>
          ))}
          <View style={{ height: 16 }} />
          <Text style={[styles.settingLabel, { color: colors.foreground, marginBottom: 12 }]}>Accent Color</Text>
          <View style={{ flexDirection: 'row', flexWrap: 'wrap', gap: 10 }}>
            {ACCENT_KEYS.map((accent) => (
              <TouchableOpacity
                key={accent}
                onPress={() => updateSettings({ accentColor: accent } as any)}
                style={{
                  width: 32,
                  height: 32,
                  borderRadius: 16,
                  backgroundColor: ACCENT_MAP[accent],
                  borderWidth: 2,
                  borderColor: (settings as any).accentColor === accent ? colors.foreground : 'transparent',
                }}
                activeOpacity={0.7}
              />
            ))}
          </View>
        </View>
"""
    orig = orig.replace(settings_comment, appearance_block + "\n" + settings_comment, 1)
    print("  ✅ Added Appearance section")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Appearance section added")

# ---------------------------------------------------------------------------
# Patch 8: WidgetSnapshotRepository.kt
# ---------------------------------------------------------------------------
def patch_android_snapshot_repo():
    file = ROOT / "android/app/src/main/java/com/forgehabits/app/WidgetSnapshotRepository.kt"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    # Add fields to data class
    old_field = "    val todayTasks: List<WidgetTodayTask>"
    if old_field not in orig:
        fail(file, "todayTasks field not found")
    new_field = old_field + ",\n    val theme: String = \"super_amoled\",\n    val accentColor: String = \"orange\""
    orig = orig.replace(old_field, new_field, 1)
    print("  ✅ Added theme, accentColor fields")

    # Parse them after todayTasks parsing
    old_parse = (
        "            val todayTasks = (0 until todayTasksArray.length()).mapNotNull { i ->\n"
        "                val t = todayTasksArray.optJSONObject(i) ?: return@mapNotNull null\n"
        "                WidgetTodayTask(\n"
        "                    id = t.optString(\"id\", \"\"),\n"
        "                    title = t.optString(\"title\", \"\"),\n"
        "                    completed = t.optBoolean(\"completed\", false)\n"
        "                )\n"
        "            }"
    )
    if old_parse not in orig:
        fail(file, "todayTasks parsing block not found")
    new_parse = old_parse + "\n" + (
        "            val theme = obj.optString(\"theme\", \"super_amoled\")\n"
        "            val accentColor = obj.optString(\"accentColor\", \"orange\")"
    )
    orig = orig.replace(old_parse, new_parse, 1)
    print("  ✅ Added theme/accent parsing")

    # Add to constructor
    old_ctor = (
        "            WidgetSnapshot(\n"
        "                version = version,\n"
        "                updatedAt = obj.optString(\"updatedAt\", \"\"),\n"
        "                today = obj.optString(\"today\", \"\"),\n"
        "                completed = obj.optInt(\"completed\", 0),\n"
        "                total = obj.optInt(\"total\", 0),\n"
        "                remaining = obj.optInt(\"remaining\", 0),\n"
        "                streak = obj.optInt(\"streak\", 0),\n"
        "                habits = habits,\n"
        "                heatmap = heatmap,\n"
        "                todayTasks = todayTasks\n"
        "            )"
    )
    if old_ctor not in orig:
        fail(file, "WidgetSnapshot constructor call not found")
    new_ctor = old_ctor.replace(
        "todayTasks = todayTasks",
        "todayTasks = todayTasks,\n                theme = theme,\n                accentColor = accentColor",
    )
    orig = orig.replace(old_ctor, new_ctor, 1)
    print("  ✅ Added constructor arguments")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Theme fields in snapshot")

# ---------------------------------------------------------------------------
# Patch 9: GlanceColors.kt
# ---------------------------------------------------------------------------
def patch_glance_colors():
    file = ROOT / "android/app/src/main/java/com/forgehabits/app/glance/GlanceColors.kt"
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    old_obj = (
        "object GlanceColors {\n"
        "    val BG = ColorProvider(Color(0xFF080808))\n"
        "    val ACCENT = ColorProvider(Color(0xFFDF5B1B))\n"
        "    val ACCENT_STRONG = ColorProvider(Color(0xFFDF5B1B))\n"
        "    val ACCENT_DIM = ColorProvider(Color(0xFF4A1E09))\n"
        "    val ACCENT_MID = ColorProvider(Color(0xFF863710))\n"
        "    val TEXT = ColorProvider(Color(0xFFF0F0F0))\n"
        "    val SUBTEXT = ColorProvider(Color(0xFF969696))\n"
        "    val TRACK = ColorProvider(Color(0xFF1C1C1C))\n"
        "\n"
        "    // Plain ARGB ints for use with android.graphics.Paint, which doesn't\n"
        "    // accept Glance's ColorProvider.\n"
        "    const val ACCENT_ARGB = 0xFFDF5B1B.toInt()\n"
        "    const val TRACK_ARGB = 0xFF1C1C1C.toInt()\n"
        "}"
    )
    if old_obj not in orig:
        fail(file, "GlanceColors object not found")
    new_class = (
        "class GlanceColors(private val theme: String, private val accentKey: String) {\n"
        "    private val accentHex: String\n"
        "        get() = when (accentKey) {\n"
        '            "orange" -> "#E05A1A"\n'
        '            "red" -> "#EF4444"\n'
        '            "maroon" -> "#800000"\n'
        '            "blue" -> "#3B82F6"\n'
        '            "green" -> "#22C55E"\n'
        '            "purple" -> "#8B5CF6"\n'
        '            "pink" -> "#EC4899"\n'
        '            "cyan" -> "#06B6D4"\n'
        '            "yellow" -> "#F59E0B"\n'
        '            else -> "#E05A1A"\n'
        "        }\n"
        "\n"
        "    val accentColor: Color\n"
        "        get() = Color(android.graphics.Color.parseColor(accentHex))\n"
        "\n"
        "    val BG: ColorProvider\n"
        '        get() = if (theme == "light") ColorProvider(Color.White) else ColorProvider(Color(0xFF000000))\n'
        "\n"
        "    val TEXT: ColorProvider\n"
        '        get() = if (theme == "light") ColorProvider(Color(0xFF0A0A0A)) else ColorProvider(Color(0xFFF2F2F2))\n'
        "\n"
        "    val SUBTEXT: ColorProvider\n"
        '        get() = if (theme == "light") ColorProvider(Color(0xFF737373)) else ColorProvider(Color(0xFF969696))\n'
        "\n"
        "    val TRACK: ColorProvider\n"
        '        get() = if (theme == "light") ColorProvider(Color(0xFFE5E5E5)) else ColorProvider(Color(0xFF1C1C1C))\n'
        "\n"
        "    val ACCENT: ColorProvider\n"
        "        get() = ColorProvider(accentColor)\n"
        "\n"
        "    val ACCENT_STRONG: ColorProvider\n"
        "        get() = ACCENT\n"
        "\n"
        "    val ACCENT_DIM: ColorProvider\n"
        "        get() = ColorProvider(accentColor.copy(alpha = 0.25f))\n"
        "\n"
        "    val ACCENT_MID: ColorProvider\n"
        "        get() = ColorProvider(accentColor.copy(alpha = 0.6f))\n"
        "\n"
        "    val ACCENT_ARGB: Int\n"
        "        get() = accentColor.toArgb()\n"
        "}"
    )
    orig = orig.replace(old_obj, new_class, 1)
    print("  ✅ Converted GlanceColors to dynamic class")

    # Update interpolateAccentColor signature
    old_sig = "fun interpolateAccentColor(pct: Float): androidx.glance.unit.ColorProvider {"
    new_sig = "fun interpolateAccentColor(pct: Float, accentArgb: Int): androidx.glance.unit.ColorProvider {"
    if old_sig not in orig:
        fail(file, "interpolateAccentColor signature not found")
    orig = orig.replace(old_sig, new_sig, 1)
    print("  ✅ Updated interpolateAccentColor signature")

    # Replace hardcoded start/end
    old_body = (
        "    val start = androidx.compose.ui.graphics.Color(0xFF4A1E09)\n"
        "    val end = androidx.compose.ui.graphics.Color(0xFFDF5B1B)"
    )
    if old_body not in orig:
        fail(file, "interpolateAccentColor body not found")
    new_body = (
        "    val end = androidx.compose.ui.graphics.Color(accentArgb)\n"
        "    val start = androidx.compose.ui.graphics.Color(\n"
        "        android.graphics.Color.argb(\n"
        "            0xFF,\n"
        "            ((end.red * 0.2f) * 255).toInt().coerceIn(0, 255),\n"
        "            ((end.green * 0.2f) * 255).toInt().coerceIn(0, 255),\n"
        "            ((end.blue * 0.2f) * 255).toInt().coerceIn(0, 255)\n"
        "        )\n"
        "    )"
    )
    orig = orig.replace(old_body, new_body, 1)
    print("  ✅ Made interpolate colors dynamic")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {file.name}: Dynamic GlanceColors")

# ---------------------------------------------------------------------------
# Patches 10-13: Glance widgets (same pattern)
# ---------------------------------------------------------------------------
def patch_glance_widget(widget_file: str, composable_name: str):
    file = ROOT / widget_file
    if not file.exists():
        fail(file, "File not found")
    backup(file)
    orig = file.read_text(encoding="utf-8")

    snapshot_line = "        val snapshot = WidgetSnapshotRepository.read(context)"
    if snapshot_line not in orig:
        fail(file, "Snapshot read line not found")
    init = (
        "        val snapshot = WidgetSnapshotRepository.read(context)\n"
        "        val colors = GlanceColors(\n"
        '            theme = snapshot?.theme ?: "super_amoled",\n'
        '            accentKey = snapshot?.accentColor ?: "orange"\n'
        "        )"
    )
    orig = orig.replace(snapshot_line, init, 1)
    print(f"  ✅ [{widget_file}] Added GlanceColors instance")

    func_sig = f"private fun {composable_name}("
    if func_sig not in orig:
        fail(file, f"{composable_name} signature not found")
    orig = orig.replace(func_sig, f"private fun {composable_name}(colors: GlanceColors, ", 1)
    print(f"  ✅ [{widget_file}] Added colors param to {composable_name}")

    call_line = f"            {composable_name}("
    if call_line not in orig:
        fail(file, f"{composable_name} call not found")
    orig = orig.replace(call_line, f"            {composable_name}(colors = colors, ", 1)
    print(f"  ✅ [{widget_file}] Passed colors to {composable_name}")

    orig = orig.replace("GlanceColors.", "colors.")
    print(f"  ✅ [{widget_file}] Replaced GlanceColors. with colors.")

    # Additional adjustment for Heatmap: update interpolateAccentColor call
    if "Heatmap" in widget_file:
        old_interp = "interpolateAccentColor(day.pct.toFloat().coerceIn(0f, 1f))"
        new_interp = "interpolateAccentColor(day.pct.toFloat().coerceIn(0f, 1f), colors.ACCENT_ARGB)"
        if old_interp in orig:
            orig = orig.replace(old_interp, new_interp, 1)
            print(f"  ✅ [{widget_file}] Updated interpolateAccentColor call")
        else:
            # try line-by-line
            lines = orig.split("\n")
            mod = False
            for i, line in enumerate(lines):
                if "interpolateAccentColor(day.pct" in line and "colors.ACCENT_ARGB" not in line:
                    lines[i] = line.replace(")", ", colors.ACCENT_ARGB)")
                    mod = True
                    break
            if mod:
                orig = "\n".join(lines)
                print(f"  ✅ [{widget_file}] Updated interpolateAccentColor call (line-based)")

    file.write_text(orig, encoding="utf-8")
    print(f"✅ {widget_file}: Dynamic colors applied")

def patch_all_android_widgets():
    widgets = [
        ("android/app/src/main/java/com/forgehabits/app/glance/CombinedGlanceWidget.kt", "CombinedContent"),
        ("android/app/src/main/java/com/forgehabits/app/glance/ProgressGlanceWidget.kt", "ProgressContent"),
        ("android/app/src/main/java/com/forgehabits/app/glance/TasksGlanceWidget.kt", "TasksContent"),
        ("android/app/src/main/java/com/forgehabits/app/glance/HeatmapGlanceWidget.kt", "HeatmapContent"),
    ]
    for wfile, composable in widgets:
        patch_glance_widget(wfile, composable)

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    print("=" * 60)
    print("ForgeHabits Appearance System – Single Incremental Patcher")
    print("=" * 60)

    # Apply in order
    patch_types()            # 1
    patch_colors()           # 2
    patch_useColors()        # 3
    patch_root_layout()      # 4
    patch_tab_layout()       # 5
    patch_habits_context()   # 6
    patch_settings_screen()  # 7
    patch_android_snapshot_repo()  # 8
    patch_glance_colors()    # 9
    patch_all_android_widgets()   # 10-13

    print("\n✅ All patches applied successfully.")
    print("Backups saved with extension .pre-appearance.bak")
    print("Rebuild the project to verify appearance switching.")

if __name__ == "__main__":
    main()
