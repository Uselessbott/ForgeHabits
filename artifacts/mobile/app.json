{
  "expo": {
    "name": "ForgeHabits",
    "slug": "ForgeHabits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forgehabits.app"
    },
    "android": {
      "package": "com.forgehabits.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#080808"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#080808",
          "defaultChannel": "forgehabits_default"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "55f5f586-09f2-43e6-91f4-8c311962535e"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
