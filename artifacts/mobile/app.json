{
  "expo": {
    "name": "ForgeHabits",
    "slug": "ForgeHabits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forgehabits.app"
    },
    "android": {
      "package": "com.forgehabits.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#080808"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#080808",
          "defaultChannel": "forgehabits_default"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "ForgeHabitsProgress",
              "label": "ForgeHabits Progress",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "resizeMode": "horizontal|vertical",
              "description": "Circular progress ring \u2014 tap to complete next habit",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ForgeHabitsTasks",
              "label": "ForgeHabits Tasks",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "resizeMode": "horizontal|vertical",
              "description": "Today's task list \u2014 tap to complete",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ForgeHabitsCombined",
              "label": "ForgeHabits",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "resizeMode": "horizontal|vertical",
              "description": "Progress + tasks",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ForgeHabitsHeatmap",
              "label": "ForgeHabits Heatmap",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "resizeMode": "horizontal|vertical",
              "description": "GitHub-style completion history",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "55f5f586-09f2-43e6-91f4-8c311962535e"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}